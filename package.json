{
  "name": "officedex",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "officecliVersion": "0.2.74",
  "scripts": {
    "prefetch:officecli": "node scripts/fetch-officecli.mjs",
    "predev": "npm run prefetch:officecli",
    "prebuild": "npm run prefetch:officecli",
    "dev": "wails dev",
    "dev:browser": "vite --host=0.0.0.0 --port=3100",
    "build": "wails build",
    "dist:mac": "npm run prefetch:officecli && wails build && node scripts/codesign-bundled-officecli.mjs --app build/bin/OfficeDex.app --source build/officecli/officecli",
    "dist:win": "npm run prefetch:officecli && wails build -platform windows/amd64",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@tanstack/react-query": "^5.66.9",
    "antd": "^6.4.2",
    "clsx": "^2.1.1",
    "docx-preview": "^0.3.7",
    "lucide-react": "^0.546.0",
    "pdfjs-dist": "^3.11.174",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^26.1.0",
    "typescript": "^5.7.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  }
}
